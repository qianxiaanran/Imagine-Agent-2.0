import React, { memo, useMemo, useEffect, useState, Suspense, lazy, forwardRef, useRef, useCallback, useSyncExternalStore } from 'react';
import { Virtuoso } from 'react-virtuoso';
import {
  Bot,
  User,
  FileText,
  Copy,
  Check,
  PencilLine,
  RefreshCw,
  ThumbsUp,
  ThumbsDown,
  Volume2,
  Square,
  AlertTriangle,
  TrendingUp,
  Download,
  Presentation,
  Loader2
} from 'lucide-react';

import MarkdownRenderer from './MarkdownRenderer';
const SourcePanel = lazy(() => import('./SourcePanel'));

const EMPTY_STREAMING_STATE = Object.freeze({ text: '', meta: null, sources: [] });

const PlainTextRenderer = memo(({ content }) => (
  <div className="whitespace-pre-wrap text-[15px] leading-relaxed text-gray-800 dark:text-gray-200">
    {content || ''}
  </div>
));

const StructuredContent = memo(({
  message,
  enableMarkdown = true,
  markdownReady = false,
  forcePlainText = false,
  streaming = false
}) => {
  const content = message?.content || '';
  const role = message?.role || '';
  const meta = message?.meta || {};

  const renderMarkdown = (text) => (
    <Suspense fallback={<div className="text-xs text-gray-400">加载中...</div>}>
      <MarkdownRenderer content={text} streaming={streaming} />
    </Suspense>
  );
  const renderMaybeMarkdown = (text) => (
    enableMarkdown && markdownReady && !meta.isPlainText && !forcePlainText
      ? renderMarkdown(text)
      : <PlainTextRenderer content={text} />
  );

  if (role !== 'assistant') {
    const attachments = Array.isArray(meta.attachments) ? meta.attachments : [];
    const remainingText = meta.remainingText ?? content;

    return (
      <div className="w-full min-w-0">
        {attachments.length > 0 && (
          <div className="mb-2 flex flex-wrap gap-2">
            {attachments.map((name, idx) => (
              <div
                key={`${name}-${idx}`}
                className="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-xs font-medium text-gray-700 dark:text-gray-200 shadow-sm"
              >
                <FileText size={14} className="text-gray-500" />
                <span className="truncate max-w-[200px]">{name}</span>
              </div>
            ))}
          </div>
        )}
        {remainingText ? renderMaybeMarkdown(remainingText) : null}
      </div>
    );
  }

  if (!content) {
    return (
      <div className="flex items-center gap-1 h-5 pt-1">
        <div className="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce [animation-delay:-0.3s]"></div>
        <div className="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce [animation-delay:-0.15s]"></div>
        <div className="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce"></div>
      </div>
    );
  }

  const structured = meta.structured || {};
  const jsonData = structured.jsonData || null;
  const preText = structured.preText ?? content;
  const hasIncompleteJson = !!structured.hasIncompleteJson;

  if (!jsonData) {
    return (
      <div className="w-full min-w-0">
        {renderMaybeMarkdown(content)}
        {hasIncompleteJson && (
          <div className="mt-2 text-xs text-gray-400 animate-pulse flex items-center gap-1">
            <Loader2 size={12} className="animate-spin" /> 正在构建结构化结果...
          </div>
        )}
      </div>
    );
  }

  return (
    <div className="flex flex-col gap-3 w-full">
      {preText && renderMaybeMarkdown(preText)}

      {jsonData.type === 'report' && (
        <div className="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden shadow-sm w-full">
          <div className="bg-blue-50/50 dark:bg-blue-900/20 p-4 border-b border-blue-100 dark:border-blue-800">
            <div className="flex items-center gap-2 mb-1">
              <FileText size={16} className="text-blue-600 dark:text-blue-400" />
              <span className="text-xs font-bold text-blue-600 dark:text-blue-400 uppercase tracking-wider">Report Outline</span>
            </div>
            <h3 className="text-lg font-bold text-gray-900 dark:text-white">{jsonData.title}</h3>
            {jsonData.subtitle && (
              <p className="text-sm text-gray-500 dark:text-gray-400 mt-1">{jsonData.subtitle}</p>
            )}
          </div>
          <div className="p-4 space-y-4">
            {jsonData.sections?.map((sec, idx) => (
              <div key={idx} className="group">
                <h4 className="flex items-center gap-2 text-sm font-bold text-gray-800 dark:text-gray-200 mb-1.5">
                  {sec.icon === 'alert-triangle' ? (
                    <AlertTriangle size={14} className="text-amber-500" />
                  ) : sec.icon === 'trending-up' ? (
                    <TrendingUp size={14} className="text-green-500" />
                  ) : (
                    <div className="w-1.5 h-1.5 rounded-full bg-blue-500"></div>
                  )}
                  {sec.heading}
                </h4>
                <div className="pl-3.5 border-l-2 border-gray-100 dark:border-gray-800 ml-0.5 text-sm text-gray-600 dark:text-gray-400 whitespace-pre-wrap leading-relaxed">
                  {renderMaybeMarkdown(sec.content)}
                </div>
              </div>
            ))}
          </div>
          <div className="px-4 py-3 bg-gray-50 dark:bg-gray-800/50 border-t border-gray-100 dark:border-gray-800 flex justify-end gap-2">
            <button className="text-xs font-medium text-blue-600 dark:text-blue-400 hover:underline flex items-center gap-1">
              <Download size={12} /> 导出 PDF
            </button>
          </div>
        </div>
      )}

      {jsonData.type === 'email' && (
        <div className="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden shadow-sm w-full relative group">
          <div className="bg-gray-50 dark:bg-gray-800 p-3 border-b border-gray-200 dark:border-gray-700 flex justify-between items-start">
            <div className="space-y-1 w-full">
              <div className="flex gap-2 text-sm">
                <span className="text-gray-500 w-10">To:</span>
                <span className="font-medium text-gray-800 dark:text-gray-200">{jsonData.recipient}</span>
              </div>
              <div className="flex gap-2 text-sm">
                <span className="text-gray-500 w-10">Sub:</span>
                <span className="font-bold text-gray-900 dark:text-white">{jsonData.subject}</span>
              </div>
            </div>
            <button
              className="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-colors"
              title="复制全文"
              onClick={() => {
                navigator.clipboard.writeText(`Subject: ${jsonData.subject}\n\n${jsonData.body}`);
              }}
            >
              <Copy size={16} />
            </button>
          </div>
          <div className="p-5 text-sm text-gray-700 dark:text-gray-300 leading-relaxed font-serif">
            {renderMaybeMarkdown(jsonData.body)}
          </div>
        </div>
      )}

      {jsonData.type === 'ppt' && (
        <div className="w-full">
          <div className="flex items-center justify-between mb-3">
            <h3 className="text-sm font-bold text-gray-700 dark:text-gray-300 flex items-center gap-2">
              <Presentation size={16} className="text-purple-500" />
              {jsonData.title}
              <span className="text-xs font-normal text-gray-400">({jsonData.total_pages} 页)</span>
            </h3>
          </div>
          <div className="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {jsonData.slides?.map((slide, idx) => (
              <div
                key={idx}
                className="bg-white dark:bg-gray-900 p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:shadow-md transition-shadow relative overflow-hidden"
              >
                <div className="absolute top-0 left-0 w-1 h-full bg-purple-500"></div>
                <div className="flex justify-between items-start mb-2 pl-2">
                  <h4 className="font-bold text-gray-800 dark:text-gray-100 text-sm">{slide.title}</h4>
                  <span className="text-[10px] font-mono text-gray-400 bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded">P{slide.page}</span>
                </div>
                <ul className="space-y-1 pl-2">
                  {slide.points?.map((p, pi) => (
                    <li key={pi} className="text-xs text-gray-600 dark:text-gray-400 flex items-start gap-1.5">
                      <span className="mt-1 w-1 h-1 rounded-full bg-gray-400 flex-shrink-0"></span>
                      {p}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  );
});

const ChatMessageItem = memo(({
  message,
  messageIndex,
  totalCount,
  allowMarkdown,
  markdownReady,
  editingMessageIndex,
  editingMessageText,
  editingMessageAttachments,
  onEditTextChange,
  onEditCancel,
  onEditSend,
  onEditStart,
  onCopy,
  onSpeak,
  onRegenerate,
  onFeedback,
  isProcessing,
  copiedIdx,
  speakingIdx,
  feedbackState
}) => {
  const isUserMessage = message?.role === 'user';
  const isStreamingAssistant = !isUserMessage && isProcessing && messageIndex === totalCount - 1;
  const isEditing = isUserMessage && editingMessageIndex === messageIndex;
  const userBubbleSize = isEditing ? 'w-full max-w-full' : 'max-w-[85%] sm:max-w-[80%]';
  const userBubblePadding = isEditing ? 'p-4' : 'py-2 px-3';

  return (
    <div className={`flex flex-col gap-1 ${isUserMessage ? 'items-end' : 'items-start'}`}>
      <div className={`flex gap-4 ${isUserMessage ? 'flex-row-reverse' : ''} group max-w-full w-full`}>
        <div
          className={`w-8 h-8 rounded-full flex-shrink-0 flex items-center justify-center border border-gray-100 dark:border-gray-700 ${
            isUserMessage ? 'bg-white dark:bg-gray-800' : 'bg-green-500 text-white'
          }`}
        >
          {isUserMessage ? <User size={16} className="text-gray-600 dark:text-gray-300" /> : <Bot size={16} />}
        </div>
        <div className="flex flex-col gap-1.5 max-w-full w-full">
          <div
            className={`rounded-2xl text-[15px] ${
              isUserMessage
                ? `bg-[#f4f4f4] dark:bg-gray-800 text-gray-900 dark:text-white rounded-tr-sm self-end ${userBubbleSize} ${userBubblePadding}`
                : 'py-2 px-3 text-gray-800 dark:text-gray-200 w-full'
            }`}
          >
            {isEditing ? (
              <div className="w-full">
                {editingMessageAttachments.length > 0 && (
                  <div className="mb-2 flex flex-wrap gap-2">
                    {editingMessageAttachments.map((name, attachmentIndex) => (
                      <div
                        key={`${name}-${attachmentIndex}`}
                        className="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 text-xs font-medium text-gray-700 dark:text-gray-200 shadow-sm"
                      >
                        <FileText size={14} className="text-gray-500" />
                        <span className="truncate max-w-[200px]">{name}</span>
                      </div>
                    ))}
                  </div>
                )}
                <textarea
                  value={editingMessageText}
                  onChange={(e) => onEditTextChange(e.target.value)}
                  rows={3}
                  autoFocus
                  className="w-full bg-transparent resize-none outline-none text-[15px] leading-relaxed text-gray-900 dark:text-white"
                />
                <div className="mt-3 flex items-center justify-end gap-2">
                  <button
                    type="button"
                    onClick={onEditCancel}
                    className="px-3 py-1.5 rounded-full text-xs font-medium border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-300 hover:bg-white/70 dark:hover:bg-gray-700/60 transition-colors"
                  >
                    取消
                  </button>
                  <button
                    type="button"
                    onClick={onEditSend}
                    disabled={(!editingMessageText.trim() && editingMessageAttachments.length === 0) || isProcessing}
                    className="px-3 py-1.5 rounded-full text-xs font-medium bg-black text-white dark:bg-white dark:text-black disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
                  >
                    发送
                  </button>
                </div>
              </div>
            ) : (
              <StructuredContent
                message={message}
                enableMarkdown={allowMarkdown}
                markdownReady={markdownReady}
                forcePlainText={false}
                streaming={isStreamingAssistant}
              />
            )}

            {message?.role === 'assistant' && message.sources && message.sources.length > 0 && (
              <Suspense fallback={<div className="text-xs text-gray-400 mt-2">加载来源...</div>}>
                <SourcePanel sources={message.sources} />
              </Suspense>
            )}
          </div>

          {isUserMessage && !isEditing && message?.content && (
            <div className="flex items-center gap-1 self-end mt-0.5 opacity-0 translate-y-1 pointer-events-none transition-all duration-200 group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto">
              <button
                onClick={() => onCopy(message.content, messageIndex)}
                className={`p-1 rounded-md border border-gray-200 dark:border-gray-700 bg-white/90 dark:bg-gray-800 text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:bg-white dark:hover:bg-gray-700 transition-colors ${
                  copiedIdx === messageIndex ? 'text-green-500' : ''
                }`}
                title="复制内容"
              >
                {copiedIdx === messageIndex ? <Check size={12} /> : <Copy size={12} />}
              </button>
              <button
                onClick={() => onEditStart(messageIndex, message)}
                disabled={isProcessing}
                className="p-1 rounded-md border border-gray-200 dark:border-gray-700 bg-white/90 dark:bg-gray-800 text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:bg-white dark:hover:bg-gray-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                title="编辑消息"
              >
                <PencilLine size={12} />
              </button>
            </div>
          )}

          {message?.role === 'assistant' && !isProcessing && message?.content && (
            <div className="flex items-center gap-1.5 ml-1 mt-0.5 animate-in fade-in duration-300">
              <button
                onClick={() => onSpeak(message.content, messageIndex)}
                className={`p-1.5 rounded-md transition-colors hover:bg-gray-100 dark:hover:bg-gray-800 ${
                  speakingIdx === messageIndex
                    ? 'text-blue-500 bg-blue-50 dark:bg-blue-900/20'
                    : 'text-gray-400 dark:text-gray-500'
                }`}
                title={speakingIdx === messageIndex ? '停止朗读' : '朗读'}
              >
                {speakingIdx === messageIndex ? <Square size={14} fill="currentColor" /> : <Volume2 size={14} />}
              </button>

              <button
                onClick={() => onCopy(message.content, messageIndex)}
                className={`p-1.5 rounded-md transition-colors hover:bg-gray-100 dark:hover:bg-gray-800 ${
                  copiedIdx === messageIndex ? 'text-green-500' : 'text-gray-400 dark:text-gray-500'
                }`}
                title="复制内容"
              >
                {copiedIdx === messageIndex ? <Check size={14} /> : <Copy size={14} />}
              </button>

              {messageIndex === totalCount - 1 && (
                <button
                  onClick={onRegenerate}
                  className="p-1.5 rounded-md transition-colors hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300"
                  title="重新生成"
                >
                  <RefreshCw size={14} />
                </button>
              )}

              <div className="h-3 w-px bg-gray-200 dark:bg-gray-800 mx-1"></div>

              <button
                onClick={() => onFeedback(messageIndex, 'up')}
                className={`p-1.5 rounded-md transition-colors hover:bg-gray-100 dark:hover:bg-gray-800 ${
                  feedbackState[messageIndex] === 'up'
                    ? 'text-green-500 bg-green-50 dark:bg-green-900/20'
                    : 'text-gray-400 dark:text-gray-500'
                }`}
                title="有帮助"
              >
                <ThumbsUp size={14} />
              </button>

              <button
                onClick={() => onFeedback(messageIndex, 'down')}
                className={`p-1.5 rounded-md transition-colors hover:bg-gray-100 dark:hover:bg-gray-800 ${
                  feedbackState[messageIndex] === 'down'
                    ? 'text-red-500 bg-red-50 dark:bg-red-900/20'
                    : 'text-gray-400 dark:text-gray-500'
                }`}
                title="无帮助"
              >
                <ThumbsDown size={14} />
              </button>
            </div>
          )}
        </div>
      </div>
    </div>
  );
});

const ChatMessageList = memo(({
  messages,
  totalCount,
  firstItemIndex,
  markdownStartIndex,
  hasMoreMessages,
  onLoadMore,
  isProcessing,
  scrollToBottomToken,
  streamingStore,
  editingMessageIndex,
  editingMessageText,
  editingMessageAttachments,
  onEditTextChange,
  onEditCancel,
  onEditSend,
  onEditStart,
  onCopy,
  onSpeak,
  onRegenerate,
  onFeedback,
  copiedIdx,
  speakingIdx,
  feedbackState,
  listClassName,
  bottomPadding
}) => {
  const [markdownReady, setMarkdownReady] = useState(true);
  const virtuosoRef = useRef(null);
  const streamingSnapshot = useSyncExternalStore(
    streamingStore?.subscribe ?? (() => () => {}),
    streamingStore?.getSnapshot ?? (() => EMPTY_STREAMING_STATE),
    streamingStore?.getSnapshot ?? (() => EMPTY_STREAMING_STATE)
  );
  const streamingAssistantText = streamingSnapshot?.text || '';
  const streamingAssistantMeta = streamingSnapshot?.meta ?? null;
  const streamingAssistantSources = Array.isArray(streamingSnapshot?.sources)
    ? streamingSnapshot.sources
    : EMPTY_STREAMING_STATE.sources;
  const lastMessage = messages[messages.length - 1];
  const isLastAssistant = lastMessage?.role === 'assistant';
  const lastMessageContent = isProcessing && isLastAssistant
    ? (streamingAssistantText || lastMessage?.content || '')
    : (lastMessage?.content || '');
  const [forceFollowOutput, setForceFollowOutput] = useState(false);
  const handleAtBottomStateChange = useCallback((atBottom) => {
    if (!atBottom && forceFollowOutput) {
      setForceFollowOutput(false);
    }
  }, [forceFollowOutput]);
  const scrollToBottom = useCallback((behavior = 'auto') => {
    if (!virtuosoRef.current) return;
    if (totalCount <= 0) return;
    try {
      virtuosoRef.current.scrollToIndex({
        index: Math.max(0, totalCount - 1),
        align: 'end',
        behavior
      });
    } catch (err) {
      void err;
    }
  }, [totalCount]);
  const forceScrollToBottom = useCallback((attempts = 4) => {
    let cancelled = false;
    let remaining = attempts;
    const tick = () => {
      if (cancelled) return;
      scrollToBottom('auto');
      remaining -= 1;
      if (remaining <= 0) return;
      setTimeout(tick, 60);
    };
    tick();
    return () => {
      cancelled = true;
    };
  }, [scrollToBottom]);

  useEffect(() => {
    let active = true;
    const preload = async () => {
      if (active) setMarkdownReady(true);
      try {
        await import('./SourcePanel');
      } catch (err) {
        void err;
      }
    };
    if (typeof window.requestIdleCallback === 'function') {
      const id = window.requestIdleCallback(preload, { timeout: 1200 });
      return () => {
        active = false;
        window.cancelIdleCallback(id);
      };
    }
    const id = setTimeout(preload, 300);
    return () => {
      active = false;
      clearTimeout(id);
    };
  }, []);

  useEffect(() => {
    if (!isProcessing) return;
    if (!virtuosoRef.current) return;
    if (totalCount <= 0) return;

    if (typeof window !== 'undefined' && typeof window.requestAnimationFrame === 'function') {
      const id = window.requestAnimationFrame(() => scrollToBottom('auto'));
      return () => window.cancelAnimationFrame(id);
    }

    const id = setTimeout(() => scrollToBottom('auto'), 0);
    return () => clearTimeout(id);
  }, [isProcessing, totalCount, lastMessageContent, bottomPadding, scrollToBottom]);

  useEffect(() => {
    if (!scrollToBottomToken) return;
    setForceFollowOutput(true);
    const cancelForceScroll = forceScrollToBottom(6);
    const releaseId = setTimeout(() => {
      setForceFollowOutput(false);
    }, 900);
    return () => {
      if (typeof cancelForceScroll === 'function') {
        cancelForceScroll();
      }
      clearTimeout(releaseId);
    };
  }, [scrollToBottomToken, forceScrollToBottom]);

  const Header = useMemo(() => {
    if (!hasMoreMessages) return () => null;
    return () => (
      <div className="flex justify-center mb-6">
        <button
          onClick={onLoadMore}
          className="text-xs font-medium text-gray-500 dark:text-gray-400 hover:text-gray-800 dark:hover:text-gray-200 px-3 py-1.5 rounded-full border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors"
        >
          加载更多
        </button>
      </div>
    );
  }, [hasMoreMessages, onLoadMore]);

  const List = useMemo(() => {
    const ListComponent = forwardRef(({ style, children }, ref) => (
      <div
        ref={ref}
        style={style}
        className={`w-full space-y-6 ${listClassName || ''}`}
      >
        {children}
      </div>
    ));
    ListComponent.displayName = 'ChatMessageListRoot';
    return ListComponent;
  }, [listClassName]);

  const Footer = useMemo(() => {
    if (!bottomPadding) return () => null;
    const FooterComponent = () => (
      <div style={{ height: bottomPadding }} aria-hidden="true" />
    );
    FooterComponent.displayName = 'ChatMessageListFooter';
    return FooterComponent;
  }, [bottomPadding]);

  return (
    <Virtuoso
      ref={virtuosoRef}
      data={messages}
      firstItemIndex={firstItemIndex}
      initialTopMostItemIndex={Math.max(0, totalCount - 1)}
      atBottomStateChange={handleAtBottomStateChange}
      followOutput={() => (forceFollowOutput || isProcessing ? 'auto' : false)}
      className="custom-scrollbar"
      style={{ height: '100%', width: '100%' }}
      components={{ Header, List, Footer }}
      itemContent={(index, message) => {
        const isStreamingLastAssistant =
          isProcessing &&
          index === totalCount - 1 &&
          message?.role === 'assistant';
        const streamingSourcesSafe = Array.isArray(streamingAssistantSources)
          ? streamingAssistantSources
          : [];
        const effectiveMessage = isStreamingLastAssistant
          ? {
              ...message,
              content: streamingAssistantText ?? message?.content,
              meta: streamingAssistantMeta ?? message?.meta,
              sources: streamingSourcesSafe.length > 0 ? streamingSourcesSafe : message?.sources
            }
          : message;
        return (
          <ChatMessageItem
            message={effectiveMessage}
            messageIndex={index}
            totalCount={totalCount}
            allowMarkdown={index >= markdownStartIndex}
            markdownReady={markdownReady}
            editingMessageIndex={editingMessageIndex}
            editingMessageText={editingMessageText}
            editingMessageAttachments={editingMessageAttachments}
            onEditTextChange={onEditTextChange}
            onEditCancel={onEditCancel}
            onEditSend={onEditSend}
            onEditStart={onEditStart}
            onCopy={onCopy}
            onSpeak={onSpeak}
            onRegenerate={onRegenerate}
            onFeedback={onFeedback}
            isProcessing={isProcessing}
            copiedIdx={copiedIdx}
            speakingIdx={speakingIdx}
            feedbackState={feedbackState}
          />
        );
      }}
    />
  );
});

export default ChatMessageList;



